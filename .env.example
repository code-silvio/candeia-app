# ── Frontend (PÚBLICO) ────────────────────────────────────────────────────────
# Expostos no bundle do navegador. A chave ANON é pública por design — a
# segurança vem da RLS (somente SELECT para anon), não de escondê-la.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-aqui-a-anon-public-key

# ── Script de seed (SECRETO — somente local) ──────────────────────────────────
# A service_role ignora RLS. NUNCA commitar, NUNCA prefixar com VITE_,
# NUNCA usar no frontend. Só o scripts/seed.js consome.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key
